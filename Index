<script>
const galleries = {
  tredx: {
    title: 'Tred-X — Flood Wheelchair Attachment',
    images: ['data:image/png;base64,','data:image/png;base64,','data:image/png;base64,']
  },
  oren: {
    title: 'Oren — Portable Washing Machine',
    images: ['data:image/png;base64,','data:image/png;base64,','data:image/png;base64,']
  },
  watering: {
    title: 'Ergonomic Watering Can',
    images: ['data:image/png;base64,','data:image/png;base64,','data:image/png;base64,','data:image/png;base64,']
  },
  raylo: {
    title: 'Raylo — Smart Cutting Board',
    images: ['data:image/png;base64,','data:image/png;base64,','data:image/png;base64,','data:image/png;base64,']
  },
  locus: {
    title: 'Locus — Pan-Handle Locator for Visual Impairment',
    images: ['data:image/png;base64,','data:image/png;base64,','data:image/png;base64,','data:image/png;base64,','data:image/png;base64,']
  },
  bed: {
    title: 'Portable Bed',
    images: ['data:image/png;base64,','data:image/png;base64,','data:image/png;base64,']
  },
  kitchencare: {
    title: 'Kitchen Care — Appliance & Packaging',
    images: ['data:image/jpeg;base64,','data:image/jpeg;base64,','data:image/jpeg;base64,']
  }
};
</script>

<script>
/* ═══════════════════════════════════════════
   PROJECT METADATA
═══════════════════════════════════════════ */
const projects = [
  {key:'tredx',    tag:'Industrial Design',    name:'TRED-X',         sub:'Flood Wheelchair Attachment',              eyebrow:'Emergency Mobility · Flood Response'},
  {key:'oren',     tag:'Consumer Product',      name:'OREN',           sub:'Portable Washing Machine',                  eyebrow:'Small-Space Living · Laundry'},
  {key:'watering', tag:'Product Design',        name:'WATERING CAN',   sub:'Ergonomic Garden Tool',                     eyebrow:'Garden & Home · Ergonomics'},
  {key:'raylo',    tag:'Kitchen Design',        name:'RAYLO',          sub:'Smart Cutting Board',                       eyebrow:'Kitchen · Precision Tools'},
  {key:'locus',    tag:'Assistive Technology',  name:'LOCUS',          sub:'Pan-Handle Locator for Visual Impairment',  eyebrow:'Accessibility · Blind Users'},
  {key:'bed',      tag:'Industrial Design',     name:'PORTABLE BED',   sub:'Emergency / Field Use',                     eyebrow:'Emergency Relief · Field Ops'},
  {key:'kitchencare',tag:'Brand & Packaging',  name:'KITCHEN CARE',   sub:'Appliance & Packaging Design',              eyebrow:'Brand Identity · Appliance'},
];
const N = projects.length;

/* ═══════════════════════════════════════════
   BUILD CARDS
═══════════════════════════════════════════ */
const stage = document.getElementById('cardStage');
const dotsContainer = document.getElementById('carDots');

projects.forEach((p, i) => {
  // Card
  const card = document.createElement('div');
  card.className = 'proj-card';
  card.dataset.index = i;
  card.innerHTML = `
    <img class="proj-card-img" src="${galleries[p.key].images[0]}" alt="${p.name}" loading="lazy">
    <div class="proj-card-info">
      <div class="proj-card-tag">${p.tag}</div>
      <div class="proj-card-name">${p.name}</div>
      <div class="proj-card-sub">${p.sub}</div>
    </div>`;

  // Click on next card → advance; click on prev card → go back
  card.addEventListener('click', () => {
    const state = card.dataset.state;
    if(state === 'next') carStep(1);
    else if(state === 'prev') carStep(-1);
  });

  stage.appendChild(card);

  // Dot
  const dot = document.createElement('div');
  dot.className = 'car-dot' + (i===0?' on':'');
  dot.addEventListener('click', () => carGoTo(i));
  dotsContainer.appendChild(dot);
});

/* ═══════════════════════════════════════════
   CAROUSEL STATE
═══════════════════════════════════════════ */
let carActive = 0;

function getState(cardIdx, activeIdx) {
  const diff = (cardIdx - activeIdx + N) % N;
  if(diff === 0) return 'active';
  if(diff === 1) return 'next';
  if(diff === N-1) return 'prev';
  return 'hidden';
}

function renderCarousel() {
  const cards = stage.querySelectorAll('.proj-card');
  cards.forEach(card => {
    const i = parseInt(card.dataset.index);
    card.dataset.state = getState(i, carActive);
  });

  // Update dots
  dotsContainer.querySelectorAll('.car-dot').forEach((d, i) => {
    d.classList.toggle('on', i === carActive);
  });

  // Update title area
  const p = projects[carActive];
  document.getElementById('carLabel').textContent = p.eyebrow;
  document.getElementById('carTitle').textContent = p.name;
  document.getElementById('carSub').textContent = p.sub;
}

function carStep(dir) {
  carActive = (carActive + dir + N) % N;
  renderCarousel();
}
function carGoTo(idx) {
  carActive = idx;
  renderCarousel();
}

// Init
renderCarousel();

/* ═══════════════════════════════════════════
   OPEN ACTIVE PROJECT → LIGHTBOX
═══════════════════════════════════════════ */
function openActive() {
  openLb(projects[carActive].key, 0);
}

/* ═══════════════════════════════════════════
   LIGHTBOX
═══════════════════════════════════════════ */
let lbKey=null, lbIdx=0;
function openLb(key,idx){ lbKey=key;lbIdx=idx;document.getElementById('lightbox').classList.add('open');document.body.style.overflow='hidden';updateLb(); }
function closeLb(){ document.getElementById('lightbox').classList.remove('open');document.body.style.overflow=''; }
function lbStep(dir){ const imgs=galleries[lbKey].images;lbIdx=(lbIdx+dir+imgs.length)%imgs.length;updateLb(); }
function updateLb(){
  const imgs=galleries[lbKey].images;
  document.getElementById('lb-title').textContent=galleries[lbKey].title;
  document.getElementById('lb-img').src=imgs[lbIdx];
  document.getElementById('lb-counter').textContent=`${lbIdx+1} / ${imgs.length}`;
  document.getElementById('lb-thumbs').innerHTML=imgs.map((s,i)=>
    `<img class="lb-thumb${i===lbIdx?' on':''}" src="${s}" onclick="lbIdx=${i};updateLb()">`).join('');
}
document.getElementById('lightbox').addEventListener('click',e=>{if(e.target.id==='lightbox')closeLb()});
document.addEventListener('keydown',e=>{
  const open=document.getElementById('lightbox').classList.contains('open');
  if(open){
    if(e.key==='Escape')closeLb();
    if(e.key==='ArrowRight')lbStep(1);
    if(e.key==='ArrowLeft')lbStep(-1);
  } else {
    if(['ArrowRight','ArrowDown'].includes(e.key)){e.preventDefault();window.scrollBy({left:window.innerWidth,behavior:'smooth'});}
    if(['ArrowLeft','ArrowUp'].includes(e.key)){e.preventDefault();window.scrollBy({left:-window.innerWidth,behavior:'smooth'});}
  }
});

/* ═══════════════════════════════════════════
   CURSOR
═══════════════════════════════════════════ */
const cdot=document.getElementById('cdot'),cring=document.getElementById('cring');
document.addEventListener('mousemove',e=>{ cdot.style.left=e.clientX+'px';cdot.style.top=e.clientY+'px';cring.style.left=e.clientX+'px';cring.style.top=e.clientY+'px'; });
document.querySelectorAll('button,a,.skill-chip,.car-dot,.lb-thumb,.proj-card[data-state="next"],.proj-card[data-state="prev"]').forEach(el=>{
  el.addEventListener('mouseenter',()=>{cdot.classList.add('h');cring.classList.add('h')});
  el.addEventListener('mouseleave',()=>{cdot.classList.remove('h');cring.classList.remove('h')});
});

/* ═══════════════════════════════════════════
   PANEL NAVIGATION
═══════════════════════════════════════════ */
function toPanel(idx){
  const p=document.getElementById('panel-'+idx);
  if(p)p.scrollIntoView({behavior:'smooth',inline:'start',block:'nearest'});
}

/* ═══════════════════════════════════════════
   WHEEL → HORIZONTAL SCROLL
═══════════════════════════════════════════ */
window.addEventListener('wheel',e=>{
  if(document.getElementById('lightbox').classList.contains('open'))return;
  e.preventDefault();
  window.scrollBy({left:e.deltaY*2,behavior:'auto'});
},{passive:false});
</script>

