<style>
:root{
  --bg:#080A10;--surface:#0D1018;--card:#121620;--border:rgba(255,255,255,0.06);
  --text:#E8E6E2;--muted:#3E4458;--sec:#7A829A;
  --blue:#3D7FFF;--blue-d:rgba(61,127,255,.12);
  --orange:#FF6B2B;--orange-d:rgba(255,107,43,.12);
  --grad-bo:linear-gradient(110deg,#3D7FFF 0%,#FF6B2B 100%);
  --grad-wb:linear-gradient(110deg,#fff 0%,#3D7FFF 100%);
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}

/* ── BODY: horizontal scroll ── */
body{
  background:var(--bg);color:var(--text);
  font-family:'Syne',sans-serif;
  overflow-x:auto;overflow-y:hidden;height:100vh;cursor:none;
}
body::-webkit-scrollbar{height:3px}
body::-webkit-scrollbar-track{background:var(--bg)}
body::-webkit-scrollbar-thumb{background:var(--grad-bo);border-radius:2px}

/* Custom cursor */
#cdot{position:fixed;width:6px;height:6px;background:var(--blue);border-radius:50%;pointer-events:none;z-index:9999;transform:translate(-50%,-50%);transition:width .15s,height .15s,background .15s}
#cring{position:fixed;width:32px;height:32px;border:1px solid rgba(61,127,255,.45);border-radius:50%;pointer-events:none;z-index:9998;transform:translate(-50%,-50%);transition:all .1s ease}
#cring.h{width:52px;height:52px;border-color:var(--orange)}
#cdot.h{background:var(--orange)}

/* ── STRIP ── */
.strip{display:flex;flex-direction:row;align-items:stretch;height:100vh;width:max-content}
.panel{position:relative;height:100vh;flex-shrink:0;overflow:hidden;width:100vw}

/* ── NAV ── */
nav{position:fixed;top:0;left:0;right:0;z-index:300;display:flex;align-items:center;justify-content:space-between;padding:24px 44px;pointer-events:none}
.nav-logo{font-family:'Cormorant Garamond',serif;font-size:18px;font-weight:300;letter-spacing:.14em;color:var(--text);pointer-events:all;text-decoration:none}
.nav-logo em{font-style:italic;background:var(--grad-bo);-webkit-background-clip:text;background-clip:text;color:transparent}
.nav-links{display:flex;gap:32px;list-style:none;pointer-events:all}
.nav-links a{font-size:10px;font-weight:700;letter-spacing:.22em;text-transform:uppercase;color:var(--sec);text-decoration:none;transition:color .2s;cursor:none}
.nav-links a:hover{color:var(--blue)}
.nav-hint{font-size:9px;letter-spacing:.2em;text-transform:uppercase;color:var(--muted);display:flex;align-items:center;gap:8px}
.nav-hint-bar{width:36px;height:1px;background:var(--grad-bo)}

@keyframes fadeUp{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)}}

/* ══════════════════════════════════
   PANEL 0 — HERO
═══════════════════════════════════ */
.p-hero{
  display:flex;flex-direction:row;align-items:flex-end;
  padding:0 60px 68px;gap:0;
}
.hero-grid{position:absolute;inset:0;background-image:linear-gradient(rgba(255,255,255,.016) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.016) 1px,transparent 1px);background-size:70px 70px;mask-image:radial-gradient(ellipse 80% 65% at 50% 45%,black 0%,transparent 80%)}
.orb1{position:absolute;top:12%;right:10%;width:400px;height:400px;border-radius:50%;background:radial-gradient(circle,rgba(61,127,255,.16) 0%,transparent 70%);pointer-events:none}
.orb2{position:absolute;bottom:18%;left:26%;width:240px;height:240px;border-radius:50%;background:radial-gradient(circle,rgba(255,107,43,.11) 0%,transparent 70%);pointer-events:none}
/* LEFT col — title + desc + cta */
.hero-content{position:relative;z-index:1;flex:1;display:flex;flex-direction:column;justify-content:flex-end}
/* RIGHT col — big name + eyebrow */
.hero-right{
  position:relative;z-index:1;
  flex:0 0 auto;
  display:flex;flex-direction:column;
  justify-content:flex-end;align-items:flex-end;
  text-align:right;
  padding-left:60px;
  padding-bottom:4px;
  opacity:0;animation:fadeUp .9s ease .6s forwards;
}
.h-eyebrow{
  font-size:10px;font-weight:700;letter-spacing:.32em;text-transform:uppercase;
  color:var(--blue);margin-bottom:14px;
  opacity:0;animation:fadeUp .8s ease .7s forwards;
}
.h-designer{
  font-family:'Cormorant Garamond',serif;
  font-size:clamp(42px,6vw,90px);
  font-weight:300;line-height:.92;
  letter-spacing:-.01em;
  background:var(--grad-wb);-webkit-background-clip:text;background-clip:text;color:transparent;
  opacity:0;animation:fadeUp .9s ease .8s forwards;
}
/* left side elements */
.h-title{font-family:'Cormorant Garamond',serif;font-size:clamp(62px,8.5vw,124px);font-weight:300;line-height:.9;letter-spacing:-.02em;margin-bottom:32px;opacity:0;animation:fadeUp .9s ease .3s forwards}
.h-title em{font-style:italic;background:var(--grad-bo);-webkit-background-clip:text;background-clip:text;color:transparent}
.h-bottom{display:flex;flex-direction:column;align-items:flex-start;opacity:0;animation:fadeUp .8s ease .5s forwards}
.h-desc{max-width:380px;font-size:13px;line-height:1.78;color:var(--sec);margin-bottom:20px}
.h-cta{display:inline-flex;align-items:center;gap:12px;font-size:10px;font-weight:700;letter-spacing:.22em;text-transform:uppercase;color:var(--text);background:none;border:1px solid var(--border);padding:12px 26px;cursor:none;transition:border-color .2s,color .2s}
.h-cta:hover{border-color:var(--blue);color:var(--blue)}
.h-arrow{width:30px;height:1px;background:currentColor;transition:width .2s}
.h-cta:hover .h-arrow{width:46px}
.h-stats{display:flex;gap:44px;align-items:flex-end;margin-top:28px}
.stat-n{font-family:'Cormorant Garamond',serif;font-size:38px;font-weight:300;line-height:1;background:var(--grad-wb);-webkit-background-clip:text;background-clip:text;color:transparent}
.stat-l{font-size:9px;letter-spacing:.2em;text-transform:uppercase;color:var(--muted);margin-top:3px}
.hero-divider{position:absolute;right:0;top:0;bottom:0;width:1px;background:linear-gradient(to bottom,transparent,var(--blue),var(--orange),transparent);opacity:.25}

/* ══════════════════════════════════
   PANEL 1 — ROTATING PROJECT CAROUSEL
   Tura-style: stacked cards, active=front+big,
   next peek right, prev peek left
═══════════════════════════════════ */
.p-carousel{
  display:flex;align-items:center;justify-content:center;
  background:var(--bg);overflow:visible;
  position:relative;
}

/* Big project title at bottom */
.carousel-title-area{
  position:absolute;
  bottom:0;left:0;right:0;
  padding:0 60px 48px;
  z-index:10;
  pointer-events:none;
}
.carousel-proj-label{
  font-size:9px;font-weight:700;letter-spacing:.3em;text-transform:uppercase;
  color:var(--orange);margin-bottom:8px;
}
.carousel-proj-title{
  font-family:'Cormorant Garamond',serif;
  font-size:clamp(48px,7vw,110px);
  font-weight:300;line-height:.9;
  letter-spacing:-.01em;
  color:var(--text);
  text-transform:uppercase;
}
.carousel-proj-sub{
  font-size:11px;letter-spacing:.18em;text-transform:uppercase;
  color:var(--sec);margin-top:10px;
}

/* Arrow buttons */
.car-prev,.car-next{
  position:absolute;bottom:52px;z-index:20;
  width:44px;height:44px;
  border:1px solid rgba(255,255,255,.18);
  background:rgba(8,10,16,.8);
  backdrop-filter:blur(8px);
  color:var(--text);font-size:20px;
  display:flex;align-items:center;justify-content:center;
  cursor:none;transition:border-color .2s,color .2s,background .2s;
  pointer-events:all;
}
.car-prev{right:180px}
.car-next{right:120px}
.car-prev:hover,.car-next:hover{border-color:var(--blue);color:var(--blue);background:rgba(61,127,255,.15)}

/* View project button */
.car-view-btn{
  position:absolute;bottom:52px;right:16px;z-index:20;
  display:inline-flex;align-items:center;gap:10px;
  font-size:9px;font-weight:700;letter-spacing:.22em;text-transform:uppercase;
  color:var(--bg);background:var(--grad-bo);
  padding:13px 22px;cursor:none;transition:opacity .2s;
  pointer-events:all;
  white-space:nowrap;
}
.car-view-btn:hover{opacity:.85}
.car-view-btn::after{content:'→';font-size:13px}

/* Progress dots */
.car-dots{
  position:absolute;bottom:18px;left:50%;transform:translateX(-50%);
  z-index:20;display:flex;gap:8px;pointer-events:all;
}
.car-dot{
  width:5px;height:5px;border-radius:50%;background:var(--muted);
  cursor:none;transition:background .25s,transform .25s;
}
.car-dot.on{background:var(--orange);transform:scale(1.6)}

/* ── CARD STACK ── */
.card-stage{
  position:relative;
  width:55vw;
  height:72vh;
  /* cards are positioned absolutely inside */
}

/* Each card */
.proj-card{
  position:absolute;
  top:0;left:0;
  width:100%;height:100%;
  background:var(--card);
  overflow:hidden;
  border:1px solid var(--border);
  cursor:none;
  /* default: hidden behind */
  transform-origin:center center;
  transition:transform .55s cubic-bezier(.4,0,.2,1),
             opacity .55s cubic-bezier(.4,0,.2,1),
             box-shadow .55s ease,
             filter .55s ease;
  will-change:transform,opacity;
}
/* States set by JS:
   data-state="active"  → front, full size
   data-state="next"    → peeking right
   data-state="prev"    → peeking left
   data-state="hidden"  → invisible behind
*/
.proj-card[data-state="active"]{
  transform:translateX(0) scale(1) rotate(0deg);
  opacity:1;
  z-index:5;
  box-shadow:0 40px 100px rgba(0,0,0,.7);
  filter:brightness(1);
}
.proj-card[data-state="next"]{
  transform:translateX(38%) scale(.82) rotate(2.5deg);
  opacity:.65;
  z-index:4;
  filter:brightness(.6);
  cursor:none;
}
.proj-card[data-state="prev"]{
  transform:translateX(-38%) scale(.82) rotate(-2.5deg);
  opacity:.55;
  z-index:3;
  filter:brightness(.45);
  cursor:none;
}
.proj-card[data-state="hidden"]{
  transform:translateX(0) scale(.7);
  opacity:0;
  z-index:1;
  pointer-events:none;
}

/* Card image */
.proj-card-img{
  width:100%;height:78%;
  object-fit:contain;
  object-position:center;
  background:#060810;
  display:block;
  padding:24px 20px;
}
/* Card info strip at bottom */
.proj-card-info{
  padding:16px 20px;
  border-top:1px solid var(--border);
  background:var(--surface);
  height:22%;
  display:flex;flex-direction:column;justify-content:center;
}
.proj-card-tag{
  font-size:8px;font-weight:700;letter-spacing:.24em;text-transform:uppercase;
  color:var(--orange);margin-bottom:4px;
}
.proj-card-name{
  font-family:'Cormorant Garamond',serif;
  font-size:clamp(18px,2vw,26px);font-weight:300;
  background:var(--grad-wb);-webkit-background-clip:text;background-clip:text;color:transparent;
  line-height:1.1;
}
.proj-card-sub{
  font-size:9px;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);margin-top:3px;
}

/* ══════════════════════════════════
   PANEL 2 — ABOUT
═══════════════════════════════════ */
.p-about{
  display:flex;flex-direction:column;justify-content:flex-start;
  align-items:flex-start;padding:100px 8vw 0;
  border-left:1px solid var(--border);
  position:relative;
}
.ab-eyebrow{font-size:11px;font-weight:700;letter-spacing:.3em;text-transform:uppercase;color:var(--orange);margin-bottom:20px}
.ab-title{font-family:'Cormorant Garamond',serif;font-size:clamp(42px,5.5vw,72px);font-weight:300;line-height:1.05;margin-bottom:24px}
.ab-title em{font-style:italic;background:var(--grad-bo);-webkit-background-clip:text;background-clip:text;color:transparent}
.ab-body{font-size:22px;line-height:1.9;color:var(--sec);max-width:none;width:100%;margin-bottom:0;flex:1;padding-bottom:140px}
.skills-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:0;width:100%;position:absolute;bottom:0;left:0;right:0;border-top:1px solid var(--border)}
.skill-chip{padding:28px 32px;border-right:1px solid var(--border);border-left:none;border-top:none;border-bottom:none;background:var(--card);display:flex;align-items:flex-start;gap:16px;transition:background .2s}
.skill-chip:hover{background:rgba(61,127,255,.06)}
.skill-chip:last-child{border-right:none}
.sk-ico{font-size:26px;margin-top:2px;flex-shrink:0}
.sk-name{font-size:13px;font-weight:700;letter-spacing:.16em;text-transform:uppercase;color:var(--text);display:block;margin-bottom:6px}
.sk-note{font-size:13px;color:var(--sec);line-height:1.5}

/* ══════════════════════════════════
   PANEL 3 — CONTACT (merged with credit)
═══════════════════════════════════ */
.p-contact{
  display:flex;flex-direction:row;align-items:stretch;
  background:var(--card);border-left:1px solid var(--border);
}
/* Left col — contact info */
.ct-left{
  flex:1;display:flex;flex-direction:column;justify-content:center;
  padding:80px 8vw;border-right:1px solid var(--border);
}
.ct-eyebrow{font-size:11px;font-weight:700;letter-spacing:.3em;text-transform:uppercase;color:var(--blue);margin-bottom:20px}
.ct-title{font-family:'Cormorant Garamond',serif;font-size:clamp(38px,5vw,68px);font-weight:300;line-height:1;margin-bottom:28px;background:var(--grad-wb);-webkit-background-clip:text;background-clip:text;color:transparent}
.ct-links{display:flex;flex-direction:column;gap:18px;margin-bottom:44px}
.ct-link{display:flex;align-items:center;gap:18px;font-size:16px;color:var(--sec);text-decoration:none;transition:color .2s;cursor:none}
.ct-link:hover{color:var(--blue)}
.ct-lbl{font-size:10px;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:var(--muted);width:86px}
.ct-cta{display:inline-flex;align-items:center;gap:14px;font-size:10px;font-weight:700;letter-spacing:.22em;text-transform:uppercase;color:var(--bg);background:var(--grad-bo);padding:15px 30px;cursor:none;transition:opacity .2s;text-decoration:none}
.ct-cta:hover{opacity:.88}

/* Right col — designer info (was credit) */
.ct-right{
  flex:0 0 340px;display:flex;flex-direction:column;
  justify-content:center;padding:80px 48px;
}
.cr-name{
  font-family:'Cormorant Garamond',serif;
  font-size:clamp(32px,4vw,56px);font-weight:300;line-height:1.02;
  margin-bottom:8px;
}
.cr-name em{font-style:italic;background:var(--grad-bo);-webkit-background-clip:text;background-clip:text;color:transparent}
.cr-role{font-size:12px;letter-spacing:.28em;text-transform:uppercase;color:var(--orange);margin-bottom:28px}
.cr-divider{width:36px;height:1px;background:var(--grad-bo);margin-bottom:24px}
.cr-tools{display:flex;flex-direction:column;gap:10px;margin-bottom:36px}
.cr-tool{display:flex;align-items:center;gap:14px;font-size:14px;color:var(--sec)}
.cr-tool-icon{font-size:20px}
.cr-copy{font-size:9px;letter-spacing:.1em;color:var(--muted);margin-top:auto}

/* ══════════════════════════════════
   LIGHTBOX
═══════════════════════════════════ */
#lightbox{position:fixed;inset:0;background:rgba(4,5,10,.97);z-index:1000;display:none;flex-direction:column;align-items:center;justify-content:center;padding:40px}
#lightbox.open{display:flex}
.lb-header{position:absolute;top:0;left:0;right:0;padding:20px 36px;display:flex;justify-content:space-between;align-items:center}
.lb-title{font-family:'Cormorant Garamond',serif;font-size:19px;font-weight:300;letter-spacing:.1em}
.lb-counter{font-size:10px;letter-spacing:.2em;color:var(--sec)}
.lb-close{background:none;border:1px solid var(--border);color:var(--sec);width:38px;height:38px;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:16px;transition:all .2s}
.lb-close:hover{border-color:var(--orange);color:var(--orange)}
.lb-main{flex:1;display:flex;align-items:center;justify-content:center;width:100%;max-height:calc(100vh - 180px)}
.lb-main img{max-width:100%;max-height:100%;object-fit:contain}
.lb-nav{position:absolute;top:50%;transform:translateY(-50%);background:rgba(13,16,24,.85);border:1px solid var(--border);color:var(--text);width:48px;height:48px;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:20px;transition:all .2s}
.lb-nav:hover{background:var(--blue-d);border-color:var(--blue);color:var(--blue)}
.lb-prev{left:16px}.lb-next{right:16px}
.lb-thumbs{display:flex;gap:7px;margin-top:18px;padding:10px}
.lb-thumb{width:58px;height:38px;object-fit:cover;opacity:.38;cursor:pointer;border:1px solid transparent;transition:all .2s}
.lb-thumb.on,.lb-thumb:hover{opacity:1;border-color:var(--orange)}

/* ── ABOUT: scattered sketch images ── */
.sketch-bg{
  position:absolute;
  inset:0;
  pointer-events:none;
  z-index:0;
  overflow:hidden;
}
.sketch{
  position:absolute;
  opacity:0.10;
  mix-blend-mode:screen;
  filter:invert(1) brightness(1.4);
  /* invert: pencil lines (dark) become light on dark bg */
}
.sketch-1{
  width:520px;
  top:8%;
  right:-40px;
  transform:rotate(6deg);
}
.sketch-2{
  width:580px;
  bottom:14%;
  left:-60px;
  transform:rotate(-5deg);
}
/* Ensure about text sits above sketches */
.ab-eyebrow,.ab-title,.ab-body{position:relative;z-index:1}
.skills-grid{z-index:1}

</style>
</head>
<body>

<div id="cdot" style="left: 1454px; top: 162px;" class=""></div>
<div id="cring" style="left: 1454px; top: 162px;" class=""></div>

<nav>
  <a class="nav-logo" href="file:///C:/Users/rimsh/Downloads/index_11.html#">Hassan <em>Mehmood</em></a>
