</nav>

<div class="strip" id="strip">

<!-- ══ PANEL 0 — HERO ══ -->
<div class="panel p-hero" id="panel-0">
  <div class="hero-grid"></div>
  <div class="orb1"></div><div class="orb2"></div>
  <div class="hero-content">
    <h1 class="h-title">Form<br><em>Meets</em><br>Function</h1>
    <div class="h-bottom">
      <p class="h-desc">A collection of industrial and product design projects — from everyday consumer goods to engineering-driven solutions. Every model crafted to solve real problems with precision and intent.</p>
      <button class="h-cta" onclick="toPanel(1)">View Projects <span class="h-arrow"></span></button>
      <div class="h-stats">
        <div><div class="stat-n">07</div><div class="stat-l">Projects</div></div>
        <div><div class="stat-n">3D</div><div class="stat-l">Rendered</div></div>
        <div><div class="stat-n">Real</div><div class="stat-l">Problems</div></div>
      </div>
    </div>
  </div>
  <div class="hero-right">
    <p class="h-eyebrow">Industrial &amp; Product Design · 3D Rendering</p>
    <p class="h-designer">Hassan<br>Mehmood</p>
  </div>
  <div class="hero-divider"></div>
</div>

<!-- ══ PANEL 1 — CAROUSEL ══ -->
<div class="panel p-carousel" id="panel-1">
  <div class="card-stage" id="cardStage">
    <!-- Cards injected by JS -->
  <div class="proj-card" data-index="0" data-state="active">
    <img class="proj-card-img" src="data:image/png;base64," alt="TRED-X" loading="lazy">
    <div class="proj-card-info">
      <div class="proj-card-tag">Industrial Design</div>
      <div class="proj-card-name">TRED-X</div>
      <div class="proj-card-sub">Flood Wheelchair Attachment</div>
    </div></div><div class="proj-card" data-index="1" data-state="next">
    <img class="proj-card-img" src="data:image/png;base64," alt="OREN" loading="lazy">
    <div class="proj-card-info">
      <div class="proj-card-tag">Consumer Product</div>
      <div class="proj-card-name">OREN</div>
      <div class="proj-card-sub">Portable Washing Machine</div>
    </div></div><div class="proj-card" data-index="2" data-state="hidden">
    <img class="proj-card-img" src="data:image/png;base64," alt="WATERING CAN" loading="lazy">
    <div class="proj-card-info">
      <div class="proj-card-tag">Product Design</div>
      <div class="proj-card-name">WATERING CAN</div>
      <div class="proj-card-sub">Ergonomic Garden Tool</div>
    </div></div><div class="proj-card" data-index="3" data-state="hidden">
    <img class="proj-card-img" src="data:image/png;base64," alt="RAYLO" loading="lazy">
